# ============================================================
# Backend environment — copy this file to .env after install
# ============================================================
#
# IMPORTANT: This package does NOT include an API key.
# Each buyer must create their own free account and paste
# their personal key below.
#
# Steps:
#   1. Register at https://dashboard.api-football.com/register
#   2. Copy your API key from the dashboard
#   3. Rename this file to .env (or copy .env.example to .env)
#   4. Replace the placeholder with your real key
#   5. Run: npm run dev
#
# Free plan: 100 requests/day, 10 requests/minute
# ============================================================

PORT=5003
ORIGIN=*
API_KEY=your_api_sports_key_here
